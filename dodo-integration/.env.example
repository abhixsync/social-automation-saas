# ── Dodo Payments ──────────────────────────────────────────────────────────────
DODO_API_KEY=""          # Dashboard → Developer → API Keys (write access needed)
DODO_WEBHOOK_SECRET=""   # Dashboard → Developer → Webhooks → your endpoint secret
DODO_ENV="test"          # "test" | "live"

# ── Your plan product IDs (create plans in Dodo Dashboard → Products) ──────────
DODO_PRODUCT_STARTER=""  # e.g. prd_xxxxxxxxxxxxxxxxxxxxxxxx
DODO_PRODUCT_PRO=""
DODO_PRODUCT_ENTERPRISE=""

# ── App ────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/yourdb"
PORT="3000"
