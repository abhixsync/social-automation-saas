# ─── Database ────────────────────────────────────────────────────────────────
# Use sslmode=verify-full for pg v9 compatibility (avoids SSL deprecation warning
# from pg-connection-string treating 'require' as an alias for 'verify-full')
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/crescova?sslmode=verify-full"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"             # production: https://crescova.online
AUTH_URL="http://localhost:3000"                # production: https://crescova.online
AUTH_SECRET=""       # NextAuth v5 — openssl rand -base64 32 (same value as NEXTAUTH_SECRET)
NEXTAUTH_SECRET=""   # v4 fallback — set both to the same value

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── LinkedIn OAuth (one shared app, tokens stored per-user) ─────────────────
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="http://localhost:3000/api/linkedin/callback"  # production: https://crescova.online/api/linkedin/callback
LINKEDIN_API_VERSION="202602"   # quarterly format — update each quarter (202605, 202608, …)

# ─── AI ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=""
ANTHROPIC_API_KEY=""

# ─── Dodo Payments ────────────────────────────────────────────────────────────
DODO_API_KEY=""                 # Dashboard → Developer → API Keys (write access)
DODO_WEBHOOK_SECRET=""          # Dashboard → Developer → Webhooks → endpoint secret (base64)
DODO_ENV="test"                 # "test" | "live"

# Dodo Product IDs (Dashboard → Products → copy product_id)
DODO_PRODUCT_PRO=""             # Subscription product — ₹999/mo or $11.99/mo (Adaptive Pricing)
DODO_PRODUCT_TOPUP=""           # One-time product — ₹99 or $0.99 (Adaptive Pricing)

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
# Upstash free tier: 500K requests/day, 256MB storage.
# Production URL format: rediss://:<password>@<host>:<port>
# BullMQ overhead with conservative settings: ~1,728 req/day (stalledInterval + lockRenew).
# Each checkRateLimit call costs 2 Redis commands (INCR + EXPIRE via pipeline).
REDIS_URL="redis://localhost:6379"

# ─── Worker ───────────────────────────────────────────────────────────────────
WORKER_HEALTH_PORT=""              # default 9000 — HTTP health endpoint inside worker container

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Crescova <noreply@crescova.app>"

# ─── Encryption (LinkedIn token storage) ─────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ─── App Kill Switch ──────────────────────────────────────────────────────────
APP_MODE="active"              # active | maintenance | coming_soon | outage | upgrading | read_only | degraded
APP_MODE_BYPASS_SECRET=""      # secret to bypass maintenance mode via ?bypass=<secret>
MAINTENANCE_UNTIL=""           # UTC ISO 8601: 2026-04-10T18:00:00Z
APP_MODE_TITLE=""              # overrides default title for current mode
APP_MODE_SUBTITLE=""           # overrides default subtitle for current mode

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=""  # comma-separated admin emails, e.g. admin@example.com,you@example.com

# ─── Vercel Blob (custom image uploads) ───────────────────────────────────────
BLOB_READ_WRITE_TOKEN=""  # Vercel Dashboard → Storage → Create Blob Store → Token

# ─── Pexels (stock photos for posts) ─────────────────────────────────────────
PEXELS_API_KEY=""  # Get from https://www.pexels.com/api/new/ (free, 200 req/hour)

# ─── OpenAI (DALL-E 3 AI image generation) ───────────────────────────────────
OPENAI_API_KEY=""  # OpenAI API key — used for ai_generated image style (~$0.04/image)

# ─── Public ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Crescova"
NEXT_PUBLIC_APP_URL="http://localhost:3000"      # production: https://crescova.online

# ─── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=""  # Set to "debug" for verbose structured JSON logging
