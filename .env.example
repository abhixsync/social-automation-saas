# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/cadence"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET=""       # NextAuth v5 — openssl rand -base64 32 (same value as NEXTAUTH_SECRET)
NEXTAUTH_SECRET=""   # v4 fallback — set both to the same value

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── LinkedIn OAuth (one shared app, tokens stored per-user) ─────────────────
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="http://localhost:3000/api/linkedin/callback"
LINKEDIN_API_VERSION="202602"   # quarterly format — update each quarter (202605, 202608, …)

# ─── AI ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=""
ANTHROPIC_API_KEY=""

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Stripe Price IDs (create in Stripe dashboard — one per plan per currency)
STRIPE_STARTER_PRICE_INR=""   # ₹499/month
STRIPE_STARTER_PRICE_USD=""   # $6/month
STRIPE_GROWTH_PRICE_INR=""    # ₹999/month
STRIPE_GROWTH_PRICE_USD=""    # $12/month
STRIPE_PRO_PRICE_INR=""       # ₹2,499/month
STRIPE_PRO_PRICE_USD=""       # $29/month

# Stripe top-up Price IDs (one-time, 100 credits = 5,000 words)
STRIPE_TOPUP_PRICE_INR=""     # ₹999
STRIPE_TOPUP_PRICE_USD=""     # $19

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Worker ───────────────────────────────────────────────────────────────────
WORKER_HEALTH_PORT=""              # default 9000 — HTTP health endpoint inside worker container

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Crescova <noreply@crescova.app>"

# ─── Encryption (LinkedIn token storage) ─────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ─── App Kill Switch ──────────────────────────────────────────────────────────
APP_MODE="active"              # active | maintenance | coming_soon | outage | upgrading | read_only | degraded
APP_MODE_BYPASS_SECRET=""      # secret to bypass maintenance mode via ?bypass=<secret>
MAINTENANCE_UNTIL=""           # UTC ISO 8601: 2026-04-10T18:00:00Z
APP_MODE_TITLE=""              # overrides default title for current mode
APP_MODE_SUBTITLE=""           # overrides default subtitle for current mode

# ─── Public ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Crescova"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
