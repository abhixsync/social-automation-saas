# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/crescova?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET=""       # NextAuth v5 — openssl rand -base64 32 (same value as NEXTAUTH_SECRET)
NEXTAUTH_SECRET=""   # v4 fallback — set both to the same value

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── LinkedIn OAuth (one shared app, tokens stored per-user) ─────────────────
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="http://localhost:3000/api/linkedin/callback"
LINKEDIN_API_VERSION="202602"   # quarterly format — update each quarter (202605, 202608, …)

# ─── AI ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=""
ANTHROPIC_API_KEY=""

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_Se7jPqjKTPff4k"              # Razorpay Key ID from Dashboard → Settings → API Keys
RAZORPAY_KEY_SECRET="YejJLvCpTcLX67W7jmprDMzh"          # Razorpay Key Secret (never expose to client)
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_Se7jPqjKTPff4k"  # Same as RAZORPAY_KEY_ID — safe to expose (used in browser)
RAZORPAY_WEBHOOK_SECRET=""      # Set in Razorpay Dashboard → Webhooks → Secret

# Razorpay Subscription Plan IDs (Dashboard → Subscriptions → Plans)
RAZORPAY_PRO_PLAN_INR=""        # plan_xxx — 999/month (99900 paise)
RAZORPAY_PRO_PLAN_USD=""        # plan_xxx — $9.99/month (999 cents)

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Worker ───────────────────────────────────────────────────────────────────
WORKER_HEALTH_PORT=""              # default 9000 — HTTP health endpoint inside worker container

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Crescova <noreply@crescova.app>"

# ─── Encryption (LinkedIn token storage) ─────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ─── App Kill Switch ──────────────────────────────────────────────────────────
APP_MODE="active"              # active | maintenance | coming_soon | outage | upgrading | read_only | degraded
APP_MODE_BYPASS_SECRET=""      # secret to bypass maintenance mode via ?bypass=<secret>
MAINTENANCE_UNTIL=""           # UTC ISO 8601: 2026-04-10T18:00:00Z
APP_MODE_TITLE=""              # overrides default title for current mode
APP_MODE_SUBTITLE=""           # overrides default subtitle for current mode

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=""  # comma-separated admin emails, e.g. admin@example.com,you@example.com

# ─── Public ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Crescova"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
