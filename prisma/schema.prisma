generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Plan {
  free
  pro
  on_hold
}

enum Currency {
  INR
  USD
}

enum Tone {
  professional
  casual
  thought_leader
  storyteller
  practitioner
  contrarian
  builder_in_public
  educator
  mentor
  funny
  pun
  meme
}

enum PostStatus {
  draft
  pending_approval
  approved
  published
  failed
  skipped
}

enum AIModel {
  llama_3_1_8b
  llama_3_3_70b
  claude_sonnet
}

enum ImageStyle {
  quote_card
  stats_card
  topic_card
  minimal_light
  minimal_dark
  list_card
  stock_photo
  ai_generated
}

enum PostLength {
  short
  medium
  long
}

// ─────────────────────────────────────────────
// NextAuth required models
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// Core user model
// ─────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  passwordHash   String?

  // Billing
  plan                   Plan     @default(free)
  currency               Currency @default(INR)
  dodoCustomerId         String?  @unique
  dodoSubscriptionId     String?  @unique
  lifetimeFree           Boolean  @default(false)

  // AI Credits (word-based: 1 credit = 50 words generated)
  aiCreditsTotal Int      @default(1000)
  aiCreditsUsed  Int      @default(0)
  creditsResetAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts         Account[]
  sessions         Session[]
  linkedInAccounts LinkedInAccount[]
  preferences      UserPreferences?
  schedules        PostSchedule[]
  posts            Post[]
  creditTopups     CreditTopup[]
  notifications    Notification[]

  @@index([dodoCustomerId])
  @@index([plan])
}

// ─────────────────────────────────────────────
// LinkedIn accounts (multi-account per user)
// ─────────────────────────────────────────────

model LinkedInAccount {
  id                   String   @id @default(cuid())
  userId               String
  sub                  String   // OpenID sub — used as urn:li:person:{sub}
  accessTokenEncrypted String   @db.Text // AES-256-GCM encrypted
  expiresAt            DateTime
  displayName          String?
  profilePicture       String?
  isActive             Boolean  @default(true)
  connectedAt          DateTime @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules PostSchedule[]
  posts     Post[]

  @@unique([userId, sub])
  @@index([userId])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────
// User preferences (topics, tone, prompt)
// ─────────────────────────────────────────────

model UserPreferences {
  id                 String   @id @default(cuid())
  userId             String   @unique
  niche              String   @default("tech professional")
  tone               Tone     @default(professional)
  contentPillars     String[]
  customPromptSuffix String?  @db.Text
  approvalMode       Boolean  @default(false)
  imageStyle            ImageStyle @default(quote_card)
  autoImage             Boolean  @default(true)
  timezone              String   @default("Asia/Kolkata")
  brandColor            String?  // hex e.g. #4f46e5 — overrides gradient on cards
  showProfilePicOnCard  Boolean  @default(false)
  carouselMode          Boolean  @default(false)
  postLength            PostLength @default(medium)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Post schedule (per LinkedIn account)
// ─────────────────────────────────────────────

model PostSchedule {
  id                String   @id @default(cuid())
  userId            String
  linkedInAccountId String
  cronExpression    String?  // stored for BullMQ repeating job
  times             String[] // e.g. ["09:00", "16:00"] in user timezone
  daysOfWeek        Int[]    // 0=Sun … 6=Sat
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedInAccount LinkedInAccount @relation(fields: [linkedInAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, linkedInAccountId])
  @@index([userId])
  @@index([isActive])
}

// ─────────────────────────────────────────────
// Posts
// ─────────────────────────────────────────────

model Post {
  id                String     @id @default(cuid())
  userId            String
  linkedInAccountId String
  topic             String
  generatedContent  String     @db.Text
  wordCount         Int
  creditsUsed       Int        // ceil(wordCount / 50)
  status            PostStatus @default(draft)
  aiModel           AIModel
  scheduledFor      DateTime?
  publishedAt       DateTime?
  errorMessage      String?    @db.Text
  includeImage      Boolean    @default(true)
  imageStyle        ImageStyle?
  customImageUrl    String?    // Vercel Blob URL for user-uploaded image
  generatedImageUrl String?    // Vercel Blob URL for image pre-generated at pending_approval creation time
  stockPhotoUrl     String?    // Pexels CDN URL — stored on first fetch for preview/publish consistency
  isCarousel        Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedInAccount LinkedInAccount @relation(fields: [linkedInAccountId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, status, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([linkedInAccountId])
  @@index([scheduledFor])
}

// ─────────────────────────────────────────────
// Credit top-ups
// ─────────────────────────────────────────────

model CreditTopup {
  id            String   @id @default(cuid())
  userId        String
  credits       Int
  amount        Int      // smallest unit: paise or cents
  currency      Currency
  dodoPaymentId String?  @unique
  dodoSessionId String?  @unique
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// App Kill Switch
// ─────────────────────────────────────────────

model SiteSetting {
  key   String @id
  value String @db.Text
}

// ─────────────────────────────────────────────
// Webhook idempotency
// ─────────────────────────────────────────────

model WebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// In-app notifications
// ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}
